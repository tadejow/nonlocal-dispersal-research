deps/build.log

# ==============================================================================
# Data and Output (Customized for your repository)
# ==============================================================================
# Typically, you do not want to track large simulation output files or raw data.
# If you WANT to track the specific SVGs and PNGs you currently have, 
# keep these commented out. 
# If you want to ignore ALL future JSONs and PNGs in the data folder, uncomment them.

# Option 1: Ignore ALL JSON data files (except configs)
# data/**/*.json

# Option 2: Ignore ALL generated images (PNGs, GIFs, SVGs)
# data/**/*.png
# data/**/*.svg
# data/**/*.gif

# If you decide to ignore a whole folder but keep one specific file, you can do:
# data/desertification/*
# !data/desertification/important_file.txt

